@font-face
  font-style: normal
  font-family: "Meslo LG"
  src: local("Meslo LG S"), url("../lib/meslo-LG/MesloLGS-Regular.ttf") format("truetype")

@font-face
  font-style: normal
  font-weight: 400
  font-family: "IBM Plex Sans"
  font-display: swap
  src: url("../lib/plex/ibm-plex-sans-latin-400-normal.woff2") format("woff2")

@font-face
  font-style: normal
  font-weight: 700
  font-family: "IBM Plex Sans Condensed"
  font-display: swap
  src: url("../lib/plex/ibm-plex-sans-condensed-latin-700-normal.woff2") format("woff2")

@font-face
  font-style: normal
  font-weight: 400
  font-family: "IBM Plex Mono"
  font-display: swap
  src: url("../lib/plex/ibm-plex-mono-latin-400-normal.woff2") format("woff2")

@font-face
  font-style: normal
  font-weight: 500
  font-family: "IBM Plex Mono"
  font-display: swap
  src: url("../lib/plex/ibm-plex-mono-latin-500-normal.woff2") format("woff2")
