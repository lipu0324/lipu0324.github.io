.highlight
  background: #0a0d0a
  color: #a9c5a9

  .code
    color: #a9c5a9

    .comment,
    .quote,
    .meta
      color: #5a7a5a

    .keyword,
    .selector-tag,
    .tag,
    .name,
    .title,
    .section,
    .type,
    .doctag
      color: #e8f5e8

    .attribute,
    .selector-id,
    .string,
    .selector-attr,
    .selector-pseudo,
    .addition
      color: #4dff88

    .regexp,
    .link,
    .number,
    .literal,
    .symbol,
    .bullet,
    .variable,
    .template-variable,
    .built_in,
    .builtin-name
      color: #7aa87a

    .deletion
      color: #ffb454

    .emphasis
      font-style: italic

    .strong
      font-weight: bold
