html
  border-top: 2px solid $color-accent-1

html:before,
html:after
  position: fixed
  top: 0
  bottom: 0
  z-index: 9998
  width: 1px
  pointer-events: none
  content: ""
  background: rgba(255, 184, 77, .34)
  box-shadow: 0 0 18px rgba(255, 184, 77, .22)

html:before
  left: unquote("max(0px, calc(50% - 29rem))")

html:after
  right: unquote("max(0px, calc(50% - 29rem))")

body
  background-image: linear-gradient(rgba(255, 184, 77, .045) 1px, transparent 1px)
  background-size: 100% 4px
  font-variant-ligatures: none
  text-shadow: 0 0 5px rgba(255, 184, 77, .24), 0 0 1px rgba(255, 211, 122, .35)

body.max-width
  box-shadow: 0 0 42px rgba(255, 184, 77, .09)

body:before
  position: fixed
  top: 0
  right: 0
  bottom: 0
  left: 0
  z-index: 9999
  pointer-events: none
  content: ""
  background: linear-gradient(rgba(255, 184, 77, .018), transparent 13rem)
  box-shadow: inset 0 0 110px rgba(255, 184, 77, .055)

body > .content
  &:before
    display: block
    margin-bottom: 1.5rem
    padding: .65rem .9rem
    border: 1px solid $color-border
    background: rgba(0, 0, 0, .92)
    color: $color-accent-1
    content: "lipu0324@github-pages:~$ ./blog"
    box-shadow: inset 0 0 18px rgba(255, 184, 77, .12)

#header
  padding-bottom: 1rem
  border-bottom: 1px dashed rgba(255, 184, 77, .42)

  h1:before,
  .h1:before
    margin-right: .45rem
    color: $color-accent-1
    content: "$"

  #nav
    text-transform: uppercase

    ul
      a
        color: $color-meta

        &:before
          content: "["

        &:after
          content: "]"

.content
  a
    color: $color-link
    underline(5px, rgba(217, 152, 54, .62))

    &:hover
      color: #000
      background: $color-link
      text-shadow: none

  h1, .h1
    color: $color-accent-1

  h2, .h2
    color: $color-accent-2

    &:before
      color: $color-accent-1

  h3
    color: $color-link

.post-list
  .post-item
    padding: .2rem 0
    border-bottom: 1px dotted rgba(106, 72, 22, .62)

    .meta
      color: $color-meta

      &:before
        margin-right: .4rem
        color: $color-accent-1
        content: "log"

    span:last-child:before
      margin-right: .4rem
      color: $color-accent-1
      content: ">"

article
  header
    padding-bottom: 1rem
    border-bottom: 1px dashed rgba(255, 184, 77, .34)

    .posttitle
      color: $color-accent-1

      &:before
        margin-right: .55rem
        color: $color-link
        content: "$ cat"

    .meta *
      color: $color-meta

  .content
    img
    video
      border: 1px solid rgba(255, 184, 77, .28)
      box-shadow: 0 0 18px rgba(255, 184, 77, .08)

    blockquote
      border-left: 2px solid $color-quote
      background: rgba(255, 204, 102, .05)
      color: $color-quote

table
  border: 1px solid rgba(106, 72, 22, .6)

th
  background: rgba(255, 184, 77, .1)

td
  border-bottom: 1px dotted rgba(106, 72, 22, .48)

code
  border-color: rgba(106, 72, 22, .74)
  background: rgba(5, 3, 0, .94)
  color: $color-accent-2

pre,
.highlight
  border: 1px solid rgba(106, 72, 22, .76)
  border-radius: 0
  background: rgba(0, 0, 0, .98)
  box-shadow: inset 0 0 24px rgba(255, 184, 77, .09), 0 0 18px rgba(255, 184, 77, .05)

.highlight
  position: relative
  padding-top: 2.4rem

  &:before
    position: absolute
    top: .55rem
    left: .9rem
    color: $color-meta
    content: "[ crt tty ]"
    letter-spacing: 0

  .btn-copy
    color: $color-meta

footer
  border-top: 1px dashed rgba(255, 184, 77, .34)

::selection
  background: $color-accent-1
  color: #000
  text-shadow: none

.highlight
  color: $color-text

  .code
    color: $color-text

    .comment,
    .quote,
    .meta
      color: $color-accent-3

    .keyword,
    .selector-tag,
    .tag,
    .name,
    .title,
    .section,
    .type,
    .doctag
      color: $color-accent-2

    .attribute,
    .selector-id,
    .string,
    .selector-attr,
    .selector-pseudo,
    .addition
      color: $color-accent-1

    .regexp,
    .link,
    .number,
    .literal,
    .symbol,
    .bullet,
    .variable,
    .template-variable,
    .built_in,
    .builtin-name
      color: $color-meta

    .deletion
      color: $color-link

@media (max-width: 480px)
  html:before,
  html:after
    display: none

  body.max-width
    border-right: 0
    border-left: 0

  .content:before
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
