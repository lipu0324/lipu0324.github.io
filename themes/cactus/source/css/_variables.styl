// Fonts
$font-family-body = "Fusion Pixel 12px Monospaced", "Menlo", "Meslo LG", "Microsoft YaHei", "Noto Sans CJK SC", monospace
$font-family-mono = "Fusion Pixel 12px Monospaced", "Menlo", "Meslo LG", "Microsoft YaHei", "Noto Sans CJK SC", monospace
$font-size = 15px
$line-height = 1.78
$page-width = 0rem + (hexo-config("page_width") || 39)
// Logo
$logo-width = 0px + (hexo-config("logo.width") || 0)
$logo-height = 0px + (hexo-config("logo.height") || 0)
$logo-grayout = hexo-config("logo.grayout") || false
// Colors
$colors = hexo-config("colorscheme") || "dark"
